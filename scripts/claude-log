#!/usr/bin/env python3
"""View past Claude Code sessions as a scrollable chat in your terminal.

Claude Code stores every session as a JSONL transcript under
~/.claude/projects/<encoded-cwd>/<session-id>.jsonl. tmux scrollback can't show
these (Claude runs in the alternate screen), but the transcripts hold the full
conversation. This renders one as color chat and pipes it through `less`.

Usage:
  claude-log                 list sessions for the current project, then pick one
  claude-log -l | --list     just list sessions (no picker)
  claude-log latest          open the most recent session
  claude-log <id-prefix>     open the session whose id starts with <id-prefix>
  claude-log -a | --all      list sessions across ALL projects
  claude-log -p <dir>        use the project for <dir> instead of the cwd

Detail level: full fidelity — user prompts, Claude's thinking, text replies,
tool calls and their results.
"""
import json
import os
import re
import sys
import subprocess

HOME = os.path.expanduser("~")
PROJECTS = os.path.join(HOME, ".claude", "projects")

# ANSI colors (only emitted when output is a tty / through less -R).
C = {
    "reset": "\033[0m", "dim": "\033[2m", "bold": "\033[1m",
    "user": "\033[1;36m",      # cyan
    "claude": "\033[1;32m",    # green
    "think": "\033[2;35m",     # dim magenta
    "tool": "\033[33m",        # yellow
    "result": "\033[2;37m",    # dim white
    "meta": "\033[2;34m",      # dim blue
}


def encode_cwd(path):
    """Mirror Claude Code's project-dir encoding: non-alphanumerics -> '-'."""
    return re.sub(r"[^a-zA-Z0-9]", "-", os.path.abspath(path))


def sessions_in(project_dir):
    """Return [(path, mtime, title, lines)] sorted newest-first."""
    out = []
    if not os.path.isdir(project_dir):
        return out
    for name in os.listdir(project_dir):
        if not name.endswith(".jsonl"):
            continue
        path = os.path.join(project_dir, name)
        title, lines = "", 0
        try:
            with open(path) as fh:
                for line in fh:
                    lines += 1
                    if title:
                        continue
                    try:
                        obj = json.loads(line)
                    except ValueError:
                        continue
                    msg = obj.get("message")
                    if isinstance(msg, dict) and msg.get("role") == "user":
                        c = msg.get("content")
                        if isinstance(c, str) and c.strip() and not c.startswith("<"):
                            title = " ".join(c.split())[:70]
        except OSError:
            continue
        out.append((path, os.path.getmtime(path), title or "(no prompt)", lines))
    out.sort(key=lambda r: r[1], reverse=True)
    return out


def fmt_time(ts):
    # Avoid importing datetime.now(); just format the file mtime.
    import datetime
    return datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")


def list_sessions(rows, show_project=False):
    if not rows:
        print("No sessions found.")
        return
    for i, row in enumerate(rows, 1):
        path, mtime, title, lines = row[:4]
        sid = os.path.basename(path)[:8]
        proj = ""
        if show_project:
            proj = "  " + C["meta"] + os.path.basename(os.path.dirname(path)) + C["reset"]
        print(f"{C['bold']}{i:>3}{C['reset']}  {C['dim']}{sid}{C['reset']}  "
              f"{fmt_time(mtime)}  {C['dim']}{lines:>5}ln{C['reset']}{proj}  {title}")


def indent(text, prefix="  "):
    return "\n".join(prefix + ln for ln in str(text).rstrip("\n").splitlines())


def render(path):
    """Render one transcript as a chat string."""
    parts = []
    parts.append(f"{C['meta']}── {path} ──{C['reset']}\n")
    with open(path) as fh:
        for line in fh:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except ValueError:
                continue
            msg = obj.get("message")
            if not isinstance(msg, dict):
                continue  # skip mode/attachment/snapshot/title bookkeeping lines
            role = msg.get("role")
            content = msg.get("content")

            if role == "user":
                if isinstance(content, str):
                    if content.startswith("<"):  # system reminders / harness wrappers
                        parts.append(f"{C['meta']}[system] {' '.join(content.split())[:200]}{C['reset']}")
                    else:
                        parts.append(f"\n{C['user']}▶ You:{C['reset']}\n{indent(content)}")
                elif isinstance(content, list):
                    for b in content:
                        if not isinstance(b, dict):
                            continue
                        if b.get("type") == "tool_result":
                            res = b.get("content", "")
                            if isinstance(res, list):
                                res = "\n".join(
                                    x.get("text", "") if isinstance(x, dict) else str(x)
                                    for x in res)
                            res = str(res)
                            if len(res) > 4000:
                                res = res[:4000] + f"\n… [{len(res)-4000} more chars]"
                            parts.append(f"{C['result']}  ↳ result:\n{indent(res, '    ')}{C['reset']}")
                        elif b.get("type") == "text":
                            parts.append(f"\n{C['user']}▶ You:{C['reset']}\n{indent(b.get('text',''))}")

            elif role == "assistant" and isinstance(content, list):
                for b in content:
                    if not isinstance(b, dict):
                        continue
                    t = b.get("type")
                    if t == "thinking":
                        # Claude Code stores thinking blocks without their text
                        # (signature only), so only show ones that have content.
                        think = b.get("thinking", "").strip()
                        if think:
                            parts.append(f"{C['think']}🧠 (thinking)\n{indent(think, '   ')}{C['reset']}")
                    elif t == "text":
                        parts.append(f"\n{C['claude']}● Claude:{C['reset']}\n{indent(b.get('text',''))}")
                    elif t == "tool_use":
                        inp = b.get("input", {})
                        summary = inp.get("command") or inp.get("file_path") or inp.get("path") \
                            or inp.get("pattern") or inp.get("description") or ""
                        summary = " ".join(str(summary).split())[:160]
                        parts.append(f"{C['tool']}  ⚙ {b.get('name','tool')}: {summary}{C['reset']}")
    return "\n".join(parts) + "\n"


def page(text):
    if not sys.stdout.isatty():
        sys.stdout.write(text)
        return
    try:
        p = subprocess.Popen(["less", "-R"], stdin=subprocess.PIPE)
        p.communicate(text.encode("utf-8", "replace"))
    except (FileNotFoundError, BrokenPipeError):
        sys.stdout.write(text)


def main(argv):
    args = list(argv)
    show_all = False
    project = os.getcwd()
    selector = None

    i = 0
    while i < len(args):
        a = args[i]
        if a in ("-a", "--all"):
            show_all = True
        elif a in ("-p", "--project"):
            i += 1
            project = args[i]
        elif a in ("-l", "--list"):
            selector = "__list__"
        elif a in ("-h", "--help"):
            print(__doc__)
            return 0
        else:
            selector = a
        i += 1

    if show_all:
        rows = []
        if os.path.isdir(PROJECTS):
            for d in os.listdir(PROJECTS):
                rows += sessions_in(os.path.join(PROJECTS, d))
        rows.sort(key=lambda r: r[1], reverse=True)
    else:
        pdir = os.path.join(PROJECTS, encode_cwd(project))
        rows = sessions_in(pdir)
        if not rows:
            print(f"No sessions for this project ({project}).")
            print("Tip: `claude-log -a` lists sessions across all projects.")
            return 1

    # Resolve which session to open.
    if selector == "__list__":
        list_sessions(rows, show_project=show_all)
        return 0
    if selector and selector != "latest":
        match = [r for r in rows if os.path.basename(r[0]).startswith(selector)]
        if not match:
            print(f"No session id starts with '{selector}'.")
            return 1
        page(render(match[0][0]))
        return 0
    if selector == "latest":
        page(render(rows[0][0]))
        return 0

    # No selector: list + interactive pick.
    list_sessions(rows, show_project=show_all)
    try:
        tty = open("/dev/tty")
        sys.stderr.write("\nOpen # (Enter for 1, q to quit): ")
        sys.stderr.flush()
        choice = tty.readline().strip()
    except OSError:
        return 0
    if choice in ("q", "Q"):
        return 0
    n = 1 if choice == "" else (int(choice) if choice.isdigit() else 0)
    if not (1 <= n <= len(rows)):
        print("Nothing selected.")
        return 1
    page(render(rows[n - 1][0]))
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
